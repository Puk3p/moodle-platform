#!/usr/bin/env bash
set -euo pipefail

echo "╔══════════════════════════════════════╗"
echo "║        PRE-COMMIT CHECKS             ║"
echo "╚══════════════════════════════════════╝"

# ── 1. Check branch name convention ──────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)
PATTERN="^(main|develop|(feature|bugfix|hotfix|chore|refactor|docs|test|release)\/[a-z0-9._-]+)$"

if [[ ! "$BRANCH" =~ $PATTERN ]]; then
    echo ""
    echo "✖ Branch name '$BRANCH' does not follow the naming convention."
    echo "  Expected: <type>/<short-description>"
    echo "  Types: feature, bugfix, hotfix, chore, refactor, docs, test, release"
    echo ""
    exit 1
fi

# ── 2. Check for debug / forbidden patterns ──────────────
FORBIDDEN_PATTERNS=(
    "System\.out\.print"
    "console\.log"
    "TODO.*HACK"
    "FIXME.*URGENT"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SOURCE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(java|ts|js|jsx|tsx)$' || true)

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    if [[ -z "$SOURCE_FILES" ]]; then break; fi
    if echo "$SOURCE_FILES" | xargs grep -l "$pattern" 2>/dev/null; then
        echo ""
        echo "✖ Found forbidden pattern '$pattern' in staged files."
        echo "  Please remove before committing."
        echo ""
        exit 1
    fi
done

# ── 3. Backend: Spotless check (only if Java files changed) ─
JAVA_FILES=$(echo "$STAGED_FILES" | grep '\.java$' || true)

if [[ -n "$JAVA_FILES" ]]; then
    echo "→ Java files changed — running Spotless check..."
    (cd backend && ./mvnw spotless:check -q 2>&1) || {
        echo ""
        echo "✖ Spotless formatting check failed."
        echo "  Run: cd backend && ./mvnw spotless:apply"
        echo ""
        exit 1
    }
    echo "✓ Spotless check passed."
fi

# ── 4. Frontend: TypeScript compile check (only if TS/HTML changed) ─
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|html)$' | grep '^frontend/' || true)

if [[ -n "$TS_FILES" ]]; then
    echo "→ Frontend files changed — running type check..."
    (cd frontend && npx ng build --configuration production 2>&1) || {
        echo ""
        echo "✖ Frontend build failed. Fix TypeScript errors before committing."
        echo ""
        exit 1
    }
    echo "✓ Frontend type check passed."
fi

echo ""
echo "✓ All pre-commit checks passed."
