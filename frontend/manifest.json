{
  "manifest_version": 3,
  "name": "Moodle Extension",
  "version": "2.0.0",
  "description": "Enhanced Moodle experience with additional features and tools.",

  "permissions": ["storage"],

  "host_permissions": ["<all_urls>"],
  "action":{
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
